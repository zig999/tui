{
  "permissions": {
    "allow": [
      "Bash(python3 *)",
      "Bash(pytest *)",
      "Bash(cat *)",
      "Bash(jq *)",
      "Bash(export *)",
      "Bash(mkdir *)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(tsc *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(cp *)",
      "Bash(echo *)",
      "Bash(head *)",
      "Bash(tail *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(chmod -R 777 *)",
      "Bash(shutdown *)",
      "Bash(reboot *)"
    ]
  },
  "hooks": {
    "PostToolUse": [],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ORCH_PROJECT_DIR=$CLAUDE_PROJECT_DIR python3 $CLAUDE_PROJECT_DIR/.claude/hooks/on_stop.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ORCH_PROJECT_DIR=$CLAUDE_PROJECT_DIR python3 $CLAUDE_PROJECT_DIR/.claude/hooks/on_subagent_stop.py"
          }
        ]
      }
    ]
  }
}
